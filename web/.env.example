# OpenAI / 9Router API key (for AI analysis features)
# Get 9Router key from https://9router.com or use OpenAI key
OPENAI_API_KEY=sk-or-v1-your-key-here

# Vercel Postgres (auto-set in Vercel deployment)
# POSTGRES_URL=postgres://...

# Feature flags
NEXT_PUBLIC_MOCK_MODE=true
NEXT_PUBLIC_APP_URL=http://localhost:3000
