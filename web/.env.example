# Local dev — uses SQLite (zero-config, file in prisma/dev.db)
DATABASE_URL="file:./dev.db"

# 9Router (preferred) — get a key from https://9router.com
# Or use OpenAI as fallback (OPENAI_API_KEY).
MINIMAX_API_KEY=***

# Auth
JWT_SECRET=veriaid-dev-secret-change-me-in-production-please-32-chars-min

# Feature flags
NEXT_PUBLIC_MOCK_MODE=false
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_AI_ENABLED=true
