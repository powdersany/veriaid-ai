# Production (PostgreSQL via Neon integration on Vercel)
# Vercel auto-injects DATABASE_URL from Neon Storage — no need to set manually.
# Format: postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# Local dev — uses SQLite (zero-config, file in prisma/dev.db).
# To use locally: change provider in prisma/schema.prisma to "sqlite"
# and set DATABASE_URL="file:./dev.db"
# DATABASE_URL="file:./dev.db"

# 9Router (preferred) — get a key from https://9router.com
# Or use OpenAI as fallback (OPENAI_API_KEY).
MINIMAX_API_KEY=***

# Auth
JWT_SECRET=veriaid-dev-secret-change-me-in-production-please-32-chars-min

# Feature flags
NEXT_PUBLIC_MOCK_MODE=false
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_AI_ENABLED=true
